{
  "name": "ekfm-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "predev": "pnpm generate:tokens",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "payload": "payload",
    "generate:tokens": "node --import tsx/esm scripts/generate-tokens.mts",
    "watch:tokens": "node --import tsx/esm scripts/watch-tokens.mts",
    "generate:types": "node --import tsx/esm scripts/generate-types.mts",
    "generate:importmap": "node --import tsx/esm scripts/generate-importmap.mts",
    "build:more-about-me-graph": "node --import tsx/esm scripts/build-more-about-me-graph.mts",
    "seed:keywords": "node --env-file=.env.local --import tsx/esm scripts/seed-keywords.mts",
    "export:keywords": "node --env-file=.env.local --import tsx/esm scripts/export-keywords.mts",
    "migrate": "node --env-file=.env.local --import tsx/esm scripts/migrate.mts migrate",
    "migrate:create": "node --env-file=.env.local --import tsx/esm scripts/migrate.mts migrate:create",
    "migrate:status": "node --env-file=.env.local --import tsx/esm scripts/migrate.mts migrate:status",
    "migrate:down": "node --env-file=.env.local --import tsx/esm scripts/migrate.mts migrate:down",
    "migrate:refresh": "node --env-file=.env.local --import tsx/esm scripts/migrate.mts migrate:refresh",
    "migrate:reset": "node --env-file=.env.local --import tsx/esm scripts/migrate.mts migrate:reset",
    "migrate:fresh": "node --env-file=.env.local --import tsx/esm scripts/migrate.mts migrate:fresh"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/storage-vercel-blob": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "graphql": "^16.14.2",
    "lucide-react": "^1.17.0",
    "next": "15.5.19",
    "payload": "3.85.1",
    "posthog-js": "^1.383.2",
    "posthog-node": "^5.36.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "d3-force": "^3.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "prettier": "3.8.4",
    "sass": "^1.100.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
