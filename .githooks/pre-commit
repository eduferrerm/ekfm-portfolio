#!/bin/sh
# Repo invariants that must not drift, enforced at commit time:
#   1. no non-1px border utilities (borders are 1px site-wide)
#   2. docs/design-system.md names roles, never quotes raw palette stops
#   3. resident facts (STACK/HOSTING/DONOT) have one home (CLAUDE.md)
#   4. the generated design-system token catalog stays in sync with globals.css
# Each is a fact we have actually watched drift; converting them to commit
# blockers makes "I forgot to update the other copy" impossible to commit.
#
# Wired via `core.hooksPath .githooks` (set by the package.json `prepare` script).

# Borders are 1px site-wide (--default-border-width in app/globals.css). The bare
# `border` utility honours that token; thicker utilities are computed from the
# value you type, so they can't be disabled in CSS — block them here instead.
if rg -nP --glob '*.{tsx,ts,css}' -g '!*.generated.*' \
   '\bborder-(?:[2-9]|[1-9][0-9])\b|\bborder-\[[^]]*(?:px|rem|em)\]' . ; then
  echo "✗ pre-commit: non-1px border utility found — borders are 1px site-wide."
  echo "  Use bare \`border\` (width comes from --default-border-width)."
  exit 1
fi

# Guard: docs/design-system.md names roles, never quotes raw palette stops —
# resolved values live in globals.css + the /design-system viewer, so quoting a
# stop in prose is the exact thing that went stale (e.g. `--card` listed slate-800
# after the token moved to slate-700). Strip inline-code spans first so token
# names (`--color-slate-900-50`) and teaching examples (`bg-slate-900`) are exempt;
# only BARE literals like a `| slate-800 |` table cell trip it.
DS="docs/design-system.md"
if [ -f "$DS" ]; then
  BARE_STOPS=$(sed 's/`[^`]*`//g' "$DS" | rg -n '\b(?:slate|lime|fuchsia|blue)-[0-9]{2,3}\b')
  if [ -n "$BARE_STOPS" ]; then
    echo "✗ pre-commit: $DS quotes raw palette stops — name the role/token instead:"
    echo "$BARE_STOPS"
    exit 1
  fi
fi

# Guard: facts owned by CLAUDE.md (always-resident guardrails) have exactly one
# home there — fail if any reappears in another tracked doc, so copies can't
# diverge. Each pattern matches the RESTATEMENT form only, so `→CLAUDE.md`
# pointers (e.g. `DONOT:→CLAUDE.md`) are exempt.
for PAT in '^STACK\[' '^HOSTING:Vercel' '^DONOT:[a-z]'; do
  DUPES=$(rg -l "$PAT" CLAUDE.md docs/*.md README.md 2>/dev/null | grep -v '^CLAUDE\.md$')
  if [ -n "$DUPES" ]; then
    echo "✗ pre-commit: resident fact /$PAT/ restated outside CLAUDE.md (single-home rule):"
    echo "$DUPES"
    exit 1
  fi
done

GENERATED="lib/design-system/tokens.generated.ts"

if ! pnpm generate:tokens >/dev/null 2>&1; then
  echo "✗ pre-commit: pnpm generate:tokens failed — fix the generator or globals.css."
  exit 1
fi

if ! git diff --quiet "$GENERATED"; then
  git add "$GENERATED"
  echo "✗ pre-commit: $GENERATED was stale — regenerated and staged it."
  echo "  Review the change and re-commit."
  exit 1
fi
