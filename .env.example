# Payload
# Public base URL of the app; used to build the GraphQL endpoint (/api/graphql).
NEXT_PUBLIC_PAYLOAD_URL=
# Payload encryption secret — generate a random value (e.g. `openssl rand -hex 32`).
PAYLOAD_SECRET=

# Database
# PostgreSQL connection string. Use a POOLED connection in production (Railway
# pooled / PgBouncer-style) for the serverless runtime. Local: Railway
# DATABASE_PUBLIC_URL. Prod: internal Railway pooled URL.
DATABASE_URL=

# Storage (Vercel Blob)
# Read/write token for the Blob store. Auto-injected in Vercel once a Blob store
# is linked; for local dev, copy it from the Vercel project's env.
BLOB_READ_WRITE_TOKEN=

# PostHog
# PostHog project API token (public client key).
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog ingestion host (e.g. https://eu.i.posthog.com).
NEXT_PUBLIC_POSTHOG_HOST=
